{
    "name": "atcoder-inbrowser-playground-extension",
    "description": "manifest.json description",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev:chrome": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build && wxt build -b firefox",
        "build:chrome": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip && wxt zip -b firefox",
        "zip:chrome": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "compile": "tsc --noEmit",
        "postinstall": "wxt prepare"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "wxt": "^0.20.20"
    },
    "dependencies": {
        "@jitl/quickjs-singlefile-browser-release-sync": "^0.32.0",
        "core-js-builder": "^3.49.0",
        "esbuild-wasm": "^0.27.4",
        "monaco-editor": "^0.55.1",
        "node-inspect-extracted": "^3.3.1",
        "pyodide": "^0.29.3",
        "quickjs-emscripten-core": "^0.32.0"
    }
}
